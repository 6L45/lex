# PostgreSQL container
LEX_PROJECT_NAME=lex
LEX_DB_CONTAINER=lex-postgres
LEX_DB_IMAGE=lex-postgres:local
LEX_DB_VOLUME=lex-postgres-data
LEX_DB_PORT=5432
POSTGRES_DB=lex
POSTGRES_USER=lex_user
POSTGRES_PASSWORD=change_me

# Data sync
LEX_CODES_ROOT=https://codes.droit.org/
LEX_MAX_XML_FILES=0
LEX_REQUEST_TIMEOUT=30
LEX_BATCH_SIZE=200

# RAG embeddings
# Provider : openai | sentence-transformers | cohere
LEX_EMBEDDING_PROVIDER=openai
# Modele selon le provider:
#   openai               : text-embedding-3-small (1536d) | text-embedding-3-large (3072d)
#   sentence-transformers: all-MiniLM-L6-v2 (384d) | paraphrase-multilingual-mpnet-base-v2 (768d)
#   cohere               : embed-multilingual-v3.0 (1024d)
LEX_EMBEDDING_MODEL=text-embedding-3-small
LEX_RAG_BATCH_SIZE=64
OPENAI_API_KEY=
# COHERE_API_KEY=

# LLM (selection d'articles via ./lex select)
# Provider : anthropic | openai
LEX_LLM_PROVIDER=anthropic
# Override du modele (sinon valeur de scripts/config.py) :
# LEX_LLM_MODEL=claude-sonnet-4-6
ANTHROPIC_API_KEY=

# Optional behavior
LEX_RUN_SYNC_ON_INIT=1
LEX_INSTALL_PY_DEPS=1
# Si python n'est pas trouve, init bascule automatiquement sur uv (.venv)
LEX_PYTHON_CMD=.venv/bin/python
